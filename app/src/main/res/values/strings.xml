    <string name="perm_privacy_guarantee">Your data stays on your device. We never sell your data.</string>
    <string name="perm_under_the_hood_title">How does this work?</string>

    <string name="perm_title_accessibility">Screen Automation (Accessibility)</string>
    <string name="perm_pitch_accessibility">To act as your co-pilot, DashBuddy needs to read Dasher offers as they pop up and tap the screen to accept or decline them based on your rules.</string>
    <string name="perm_hood_accessibility">We use Android\'s AccessibilityService. Our engine only looks at the screen when the Dasher app is open. Strict \'Sensitive Screen\' blockers completely shut down our \'eyes\' if you open your bank app or personal texts.</string>
    <string name="perm_action_accessibility">Enable Automation</string>

    <string name="perm_title_listener">Tip Radar (Notifications)</string>
    <string name="perm_pitch_listener">To catch tip updates and other notifications, DashBuddy needs to read your Dasher notifications.</string>
    <string name="perm_hood_listener">We use the NotificationListenerService to listen *only* for Dasher notifications. We instantly ignore notifications from messages, emails, or other personal apps.</string>
    <string name="perm_action_listener">Enable Radar</string>

    <string name="perm_title_location">Background Location</string>
    <string name="perm_pitch_location">DashBuddy tracks your miles while you are dashing so you can calculate your actual profit after gas and wear-and-tear.</string>
    <string name="perm_hood_location">We only ping your GPS while an active session is running. Once you end the session, our Odometer shuts down completely to save your battery and protect your privacy.</string>
    <string name="perm_action_location">Grant Location</string>

    <string name="perm_title_post_notif">Bubble Alerts</string>
    <string name="perm_pitch_post_notif">DashBuddy uses notifications to keep the floating Bubble alive and to alert you of high-paying offers.</string>
    <string name="perm_hood_post_notif">This is a standard Android permission to ensure the OS doesn\'t kill the app in the background while you are working. For full functionality, enabling the bubble is recommended!</string>
    <string name="perm_action_post_notif">Enable Alerts</string>

    <string name="perm_title_bubbles">Floating HUD</string>
    <string name="perm_pitch_bubbles">To show you the math over the DoorDash app, DashBuddy needs permission to pop out into a floating window.</string>
    <string name="perm_action_bubbles">Enable Bubbles</string>
    <string name="perm_hood_bubbles">Android heavily restricts floating windows. Please ensure you select "All conversations can bubble" on the next screen so the HUD works automatically!</string>

    <string name="perm_toast_bubbles_hint">Select \"All conversations can bubble\"</string>
    <string name="perm_toast_accessibility_hint">Look for \'DashBuddy\' and turn it on.</string>


