// Section: Navigation & customer comms — generic navigation + chat.
{
  "$schema": "../../../docs/rules.fragment.schema.json",
  "screens": [
    {
      "id": "doordash.screen.nav_arriving",
      "priority": 69,
      "comment": "#745: the arriving_at_title mask is a documented residual with NO normalize — it is store-ambiguous (renders a STORE on a pickup approach, an address/customer on a dropoff approach), so a customer-name canonical key would corrupt a store token; and this surface feeds no store-lineage join, so the mask hex never needs to equal a persisted customerNameHash. Whole-token mask, un-normalized.",
      "redact": [
        {
          "find": {
            "hasIdSuffix": "arriving_at_title"
          }
        }
      ],
      "require": {
        "any": [
          {
            "exists": {
              "hasIdSuffix": "arriving_at_subtitle"
            }
          },
          {
            "exists": {
              "hasIdSuffix": "arriving_at_title"
            }
          },
          {
            "exists": {
              "hasIdSuffix": "bottom_sheet_arrived_header_v2"
            }
          }
        ]
      },
      "reject": [
        {
          "exists": {
            "hasIdSuffix": "bottom_sheet_task_title"
          }
        }
      ]
    },
    {
      "id": "doordash.screen.navigation_generic",
      "priority": 95,
      "branches": [
        {
          "state": {
            "flow": "idle",
            "modeHint": "online"
          },
          "reject": [
            {
              "allTextContains": "accept"
            },
            {
              "allTextContains": "decline"
            }
          ],
          "require": {
            "all": [
              {
                "allTextContainsAll": [
                  "min",
                  "exit"
                ]
              },
              {
                "allTextContainsAny": [
                  "mi",
                  "ft"
                ]
              }
            ]
          }
        },
        {
          "state": {
            "modeHint": "online"
          },
          "reject": [
            {
              "allTextContains": "accept"
            },
            {
              "allTextContains": "decline"
            }
          ],
          "require": {
            "exists": {
              "any": [
                {
                  "hasIdSuffix": "maneuverView"
                },
                {
                  "hasIdSuffix": "mainManeuverLayout"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "id": "doordash.screen.chat",
      "priority": 92,
      "reject": [
        {
          "allTextContains": "folder"
        }
      ],
      "require": {
        "allTextContainsAll": [
          "dasher",
          "messages"
        ]
      }
    },
    {
      "id": "doordash.screen.chat_conversation",
      "priority": 89,
      "comment": "#745: the chat nav-bar title IS the customer name → normalize so its mask hex matches the canonical-key customerNameHash the delivery surfaces persist (one customer masks identically across chat + dropoff). The message bodies are free customer text, not a name to join on — masked whole, un-normalized (canonicalizing a sentence would be meaningless).",
      "redact": [
        {
          "find": {
            "hasIdSuffix": "textView_navBar_title"
          },
          "normalize": "customerName"
        },
        {
          "find": {
            "hasIdSuffix": "message_self_message"
          }
        },
        {
          "find": {
            "hasIdSuffix": "message_other_message"
          }
        },
        {
          "find": {
            "hasIdSuffix": "admin_message_text"
          }
        }
      ],
      "require": {
        "exists": {
          "any": [
            {
              "hasIdSuffix": "ddchat_holder_base"
            },
            {
              "hasIdSuffix": "inputChannelView"
            },
            {
              "hasIdSuffix": "message_recycler_view"
            },
            {
              "hasIdSuffix": "message_self_message"
            }
          ]
        }
      }
    }
  ],
  "clicks": [
    {
      "id": "doordash.click.open_chat",
      "priority": 45,
      "intent": "open_chat",
      "require": {
        "hasIdSuffix": "chat_button_internal"
      }
    }
  ]
}
